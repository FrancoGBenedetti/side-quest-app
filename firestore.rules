rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ─── Collection Group Queries ────────────────────────────────────────────
    match /{path=**}/subscriptions/{subscriberId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isOwner(userId)
        && request.resource.data.uid == userId;

      allow update: if (isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['uid', 'createdAt', 'email']))
        || (isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['pendingRequestIds', 'sentRequestIds', 'friendIds', 'updatedAt', 'completedQuestsCount']));

      allow delete: if false;

      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Completed quests history subcollection
      // Escrita por el owner del quest al confirmar (cualquier usuario autenticado)
      // Leída por el propio usuario (perfil) y por cualquiera autenticado (perfiles públicos)
      match /completedQuests/{questId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isOwner(userId);
      }
    }

    // ─── Sidequests ──────────────────────────────────────────────────────────
    match /sidequests/{sidequestId} {
      allow read: if isSignedIn() && (
        resource.data.visibility == 'public' ||
        isOwner(resource.data.ownerId) ||
        exists(/databases/$(database)/documents/sidequests/$(sidequestId)/subscriptions/$(request.auth.uid))
      );

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'open';

      // Solo el owner puede modificar el documento completo del quest.
      // Cualquier usuario autenticado puede actualizar el contador al suscribirse/desuscribirse.
      allow update: if isSignedIn() && (
        isOwner(resource.data.ownerId) ||
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['subscribersCount', 'status', 'updatedAt'])
        )
      );

      allow delete: if isSignedIn() && isOwner(resource.data.ownerId);

      // ── Subscriptions subcollection ─────────────────────────────────────
      match /subscriptions/{subscriberId} {
        // Query de lectura
        allow read: if isSignedIn() && (
          isOwner(get(/databases/$(database)/documents/sidequests/$(sidequestId)).data.ownerId) ||
          isOwner(subscriberId)
        );

        // El propio usuario (auto-suscripción) O el owner del quest (invitación)
        allow create: if isSignedIn() && (
          isOwner(subscriberId) ||
          isOwner(get(/databases/$(database)/documents/sidequests/$(sidequestId)).data.ownerId)
        );

        // Owner del quest O el propio suscriptor (campos limitados)
        allow update: if isSignedIn() && (
          isOwner(get(/databases/$(database)/documents/sidequests/$(sidequestId)).data.ownerId) ||
          (isOwner(resource.data.userId) &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'completionPending', 'evidenceData', 'evidenceRejected', 'updatedAt']))
        );

        // Suscriptor (abandon/reject) O owner del quest (removeSubscriber)
        allow delete: if isSignedIn() && (
          isOwner(resource.data.userId) ||
          isOwner(get(/databases/$(database)/documents/sidequests/$(sidequestId)).data.ownerId)
        );
      }
    }

    // ─── Friend requests ─────────────────────────────────────────────────────
    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.fromUserId) ||
        isOwner(resource.data.toUserId)
      );

      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isSignedIn() && isOwner(resource.data.toUserId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'updatedAt']);

      allow delete: if isSignedIn() && isOwner(resource.data.fromUserId);
    }
  }
}
